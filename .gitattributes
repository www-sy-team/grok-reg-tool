# 统一用 LF,避免 Windows 检出时整文件 CRLF 改动
* text=auto eol=lf

# 脚本和源码固定 LF，避免 Docker/Linux 下执行异常
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# 二进制文件不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
