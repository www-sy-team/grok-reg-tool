# ============================================
# grok-reg-tool 环境变量示例
# docker 部署：复制为 docker/.env 并填写
# 本地 npm 部署：大多数项在 WebUI 设置页里配，无需 .env
# ============================================

# Web 服务监听端口（docker 下映射到宿主机的端口）
WEB_PORT=6657
PORT=6657
BIND_HOST=0.0.0.0

# WebUI 配置 / 账号数据目录（docker 下建议挂载持久化卷）
DATA_DIR=/data

# Python 解释器与注册脚本目录
PYTHON_PATH=/usr/local/bin/python3
REGISTER_DIR=/app/register
SSO_DIR=/data/sso

# 默认注册轮数
RUN_COUNT=10

# 邮件后端（兼容 cloudflare_temp_email）
MAIL_API_BASE=
MAIL_ADMIN_AUTH=
MAIL_DOMAIN=

# 可选代理
HTTP_PROXY=
BROWSER_PROXY=

# 浏览器可执行文件路径（docker 镜像内为 chromium）
BROWSER_PATH=/usr/bin/chromium

# Web 默认账号密码 admin/admin 会打印在启动日志中，首次登录强制修改
